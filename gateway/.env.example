# Gateway runtime
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# HTTP behavior
REQUEST_TIMEOUT_MS=1500
LEADER_DISCOVERY_TIMEOUT_MS=1200
HEALTH_CHECK_INTERVAL_MS=3000
QUEUE_FLUSH_BATCH_SIZE=100

# Replica addresses on Docker network
REPLICA1_URL=http://replica1:5000
REPLICA2_URL=http://replica2:5000
REPLICA3_URL=http://replica3:5000

# Optional alternative: JSON blob instead of individual replica vars
# REPLICAS_JSON={"replica1":"http://replica1:5000","replica2":"http://replica2:5000","replica3":"http://replica3:5000"}
